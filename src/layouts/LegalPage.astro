---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  updated: string;
  noindex?: boolean;
}

const { title, description, updated, noindex = false } = Astro.props;
---

<BaseLayout title={`${title}｜SeasideBeer`} description={description} noindex={noindex}>
  <section class="legal-hero">
    <div class="container legal-head">
      <p class="eyebrow">LEGAL</p>
      <h1>{title}</h1>
      <p>{description}</p>
      <time>{updated}</time>
    </div>
  </section>
  <section class="legal-section">
    <div class="container legal-body">
      <slot />
    </div>
  </section>
</BaseLayout>

<style>
  .legal-hero {
    padding: 80px 0 70px;
    background: linear-gradient(135deg, var(--sea-50), white 72%);
  }

  .legal-head {
    max-width: 820px;
  }

  .legal-head h1 {
    margin-bottom: 18px;
    font-size: clamp(38px, 6vw, 62px);
    letter-spacing: -0.06em;
    line-height: 1.25;
  }

  .legal-head > p:not(.eyebrow) {
    max-width: 680px;
    margin-bottom: 18px;
    color: var(--ink-600);
  }

  .legal-head time {
    color: var(--ink-500);
    font-size: 11px;
  }

  .legal-section {
    padding: 82px 0 112px;
  }

  .legal-body {
    max-width: 820px;
    color: var(--ink-700);
    font-size: 15px;
  }

  .legal-body :global(h2) {
    margin: 56px 0 18px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--line);
    color: var(--ink-950);
    font-size: 24px;
    letter-spacing: -0.04em;
  }

  .legal-body :global(h2:first-child) {
    margin-top: 0;
  }

  .legal-body :global(p),
  .legal-body :global(li) {
    line-height: 2;
  }

  .legal-body :global(a) {
    color: var(--sea-700);
    font-weight: 750;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .legal-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 22px 0;
    font-size: 14px;
  }

  .legal-body :global(th),
  .legal-body :global(td) {
    padding: 16px;
    border: 1px solid var(--line);
    text-align: left;
    vertical-align: top;
  }

  .legal-body :global(th) {
    width: 28%;
    color: var(--ink-900);
    background: var(--cloud);
  }

  .legal-body :global(.legal-note) {
    padding: 20px 22px;
    border-left: 4px solid var(--sea-500);
    border-radius: 0 12px 12px 0;
    color: var(--ink-700);
    background: var(--sea-50);
    font-size: 13px;
  }

  @media (max-width: 680px) {
    .legal-hero {
      padding: 58px 0 52px;
    }

    .legal-section {
      padding: 58px 0 78px;
    }

    .legal-body :global(table),
    .legal-body :global(tbody),
    .legal-body :global(tr),
    .legal-body :global(th),
    .legal-body :global(td) {
      display: block;
      width: 100%;
    }

    .legal-body :global(tr) {
      margin-bottom: 14px;
    }

    .legal-body :global(td) {
      border-top: 0;
    }
  }
</style>
