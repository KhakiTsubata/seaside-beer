---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import bookCover from '../assets/book-cover.jpg';
import { book } from '../data/site';

const insights = (await getCollection('insights', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);
const dateFormatter = new Intl.DateTimeFormat('ja-JP', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});
---

<BaseLayout image="/og.png">
  <section class="water-hero" aria-labelledby="home-title">
    <div class="hero-caustics" aria-hidden="true"></div>
    <div class="hero-wash" aria-hidden="true"></div>

    <div class="hero-collage" aria-hidden="true">
      <div class="hero-photo hero-photo-city"></div>
      <div class="hero-photo hero-photo-workshop"></div>
      <div class="hero-photo hero-photo-coast"></div>
      <i class="water-ribbon ribbon-one"></i>
      <i class="water-ribbon ribbon-two"></i>
    </div>

    <div class="container-wide hero-layout">
      <div class="hero-copy">
        <p class="hero-location">MATSUYAMA / EHIME</p>
        <h1 id="home-title"><span>AIと、</span><span>地域のあいだに。</span></h1>
        <p class="hero-lead">
          AIがひらくのは、効率だけじゃない。<br />
          働く人の時間と、若者の選択肢を、松山から増やしていく。
        </p>

        <div class="mobile-hero-visual" aria-hidden="true">
          <span>FROM MATSUYAMA</span>
        </div>

        <nav class="hero-services" aria-label="主なサービス">
          <a href="/services/corporate/">
            <span class="service-number">01</span>
            <strong>企業支援</strong>
            <i aria-hidden="true">→</i>
          </a>
          <a href="/services/corporate/">
            <span class="service-number">02</span>
            <strong>AI研修</strong>
            <i aria-hidden="true">→</i>
          </a>
          <a href="/academy/">
            <span class="service-number">03</span>
            <strong>若者育成</strong>
            <i aria-hidden="true">→</i>
          </a>
        </nav>

        <a class="hero-action" href="/insights/">活動を見る <span aria-hidden="true">→</span></a>
      </div>
    </div>

    <div class="matsuyama-badge" aria-label="活動拠点 松山">
      <span>EHIME</span>
      <strong>松山</strong>
    </div>
  </section>

  <section class="thought-section" id="mission">
    <div class="container-wide thought-grid">
      <div class="section-marker" data-reveal>
        <span>01</span>
        <p>OUR POINT OF VIEW</p>
      </div>
      <div class="thought-copy" data-reveal>
        <p class="jp-kicker">AIで、人の時間はどこへ向かうか。</p>
        <h2>人の時間を、<br /><em>未来へ返す。</em></h2>
        <div class="thought-note">
          <p>
            調べる、まとめる、下書きをつくる。AIに任せられる作業は、これからも増えていきます。
            だからこそ、浮いた時間を何に使うかを考えたい。顧客と話す。若者を育てる。まだない商売をつくる。AIの先に生まれる人の時間を、松山の未来へつなぎます。
          </p>
          <a class="water-link" href="/about/">SeasideBeerについて <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </div>
  </section>

  <section class="book-section" aria-labelledby="book-title">
    <div class="container-wide book-grid">
      <div class="section-marker book-marker" data-reveal>
        <span>02</span>
        <p>BOOK / NOW AVAILABLE</p>
      </div>

      <div class="book-visual" data-reveal>
        <Image
          class="book-cover"
          src={bookCover}
          alt={`『${book.title}』の表紙`}
          width={780}
          height={1248}
          format="webp"
          quality={82}
          loading="lazy"
          decoding="async"
        />
      </div>

      <div class="book-copy" data-reveal>
        <p class="jp-kicker">経営者・管理職のための、最初の一冊。</p>
        <h2 id="book-title">AIを、<br /><em>会社の仕事へ。</em></h2>
        <p class="book-name">『{book.title}』</p>
        <p class="book-subtitle">{book.subtitle}</p>
        <p class="book-description">
          生成AIを試して終わらせず、実際の業務へ移すには何から始めればいいのか。仕事の選び方から、社内で使い続けるための90日までを一冊にまとめました。
        </p>
        <p class="book-author">{book.author} 著</p>
        <a class="book-link" href={book.href} target="_blank" rel="noopener noreferrer">
          Amazonで本を見る <span aria-hidden="true">↗</span>
        </a>
      </div>
    </div>
  </section>

  <section class="services-section">
    <div class="container-wide">
      <header class="water-heading" data-reveal>
        <div><span>03</span><p>WHAT WE DO</p></div>
        <h2>AIを、知識から<br /><em>現場の力へ。</em></h2>
      </header>

      <div class="service-current">
        <article class="service-card card-business" data-reveal>
          <div class="service-card-top"><span>FOR BUSINESS</span><b>01</b></div>
          <div>
            <h3>企業向けAI支援</h3>
            <p>時間がかかっている仕事を一つ選び、AIで試し、現場で使える手順まで残します。</p>
          </div>
          <a href="/services/corporate/">支援内容を見る <span aria-hidden="true">→</span></a>
        </article>
        <article class="service-card card-training" id="training" data-reveal>
          <div class="service-card-top"><span>PRACTICAL TRAINING</span><b>02</b></div>
          <div>
            <h3>実務で使うAI研修</h3>
            <p>参加者の実際の資料や業務を持ち込み、研修中に成果物を一つ完成させます。</p>
          </div>
          <a href="/contact/">初回無料相談へ <span aria-hidden="true">→</span></a>
        </article>
        <article class="service-card card-talent" data-reveal>
          <div class="service-card-top"><span>FOR YOUNG TALENT</span><b>03</b></div>
          <div>
            <h3>若者AI人材育成</h3>
            <p>HP、資料、小さなアプリ。企業に見せ、自分で説明できる制作物を持つ10人を育てます。</p>
          </div>
          <a href="/academy/">育成構想を見る <span aria-hidden="true">→</span></a>
        </article>
      </div>
    </div>
  </section>

  <section class="proof-section">
    <div class="proof-water" aria-hidden="true"></div>
    <div class="container-wide proof-grid">
      <div class="proof-number" data-reveal>
        <span>FIRST MILESTONE</span>
        <strong>10</strong>
        <small>PEOPLE WITH PROOF</small>
      </div>
      <div class="proof-copy" data-reveal>
        <p class="section-index">企業に見せられる10人</p>
        <h2>10人の作品から、<br /><em>未来を見せる。</em></h2>
        <p>
          一人ずつ完成物を持ち、どこをAIへ任せ、どこを自分で直したか説明する。最初の10人がそこまで届いたら、企業、大学、地域へ見せます。
        </p>
        <ol>
          <li><span>01</span>課題を選ぶ</li>
          <li><span>02</span>AIと形にする</li>
          <li><span>03</span>人が直す</li>
          <li><span>04</span>企業へ見せる</li>
        </ol>
      </div>
    </div>
  </section>

  <section class="journal-section">
    <div class="container-wide">
      <header class="water-heading journal-heading" data-reveal>
        <div><span>04</span><p>ACTIVITY / JOURNAL</p></div>
        <h2>動きながら、<br /><em>言葉にしていく。</em></h2>
        <a class="water-link" href="/insights/">すべて見る <span aria-hidden="true">→</span></a>
      </header>

      <div class="journal-grid">
        {insights.map((entry, index) => (
          <a class="journal-card" href={`/insights/${entry.id}/`} data-reveal>
            <div class={`journal-visual visual-${index + 1}`} aria-hidden="true">
              <span>0{index + 1}</span>
            </div>
            <div class="journal-meta">
              <span>{entry.data.category}</span>
              <time datetime={entry.data.publishedAt.toISOString()}>{dateFormatter.format(entry.data.publishedAt)}</time>
            </div>
            <h3>{entry.data.title}</h3>
            <span class="journal-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
      <p class="visual-disclaimer">このページの写真は、事業の方向を伝えるために生成したコンセプトビジュアルです。実績写真ではありません。実際の講座や支援の様子は、公開許可が取れたものから掲載します。</p>
    </div>
  </section>

  <section class="home-cta">
    <div class="container-wide home-cta-inner" data-reveal>
      <p>FREE FIRST CONSULTATION</p>
      <h2>まだ名前のない、<br /><em>相談から。</em></h2>
      <div class="home-cta-copy">
        <p>初回相談は無料です。貝崎泰我が直接、時間のかかっている業務を一つ伺い、次の一歩を整理します。</p>
        <a href="/contact/">初回無料相談へ <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .water-hero {
    position: relative;
    min-height: max(790px, 100svh);
    overflow: hidden;
    color: var(--ocean);
    background:
      radial-gradient(circle at 16% 20%, rgba(255,255,255,.96) 0, rgba(255,255,255,.54) 20%, transparent 44%),
      linear-gradient(135deg, #dff8ff 0%, #c8f1ff 42%, #a9e9fb 100%);
  }

  .hero-caustics {
    position: absolute;
    z-index: 0;
    inset: -18% -10% auto 38%;
    height: 62%;
    opacity: .54;
    background:
      radial-gradient(ellipse at 50% 50%, transparent 52%, rgba(255,255,255,.72) 54%, transparent 59%) 0 0 / 130px 92px,
      radial-gradient(ellipse at 50% 50%, transparent 54%, rgba(255,255,255,.48) 56%, transparent 61%) 48px 26px / 170px 118px;
    filter: blur(3px);
    mix-blend-mode: screen;
    transform: rotate(-8deg);
    animation: caustic-drift 16s ease-in-out infinite alternate;
  }

  @keyframes caustic-drift { to { transform: translate3d(-3%, 4%, 0) rotate(-5deg) scale(1.05); } }

  .hero-wash {
    position: absolute;
    z-index: 2;
    inset: 0 auto 0 0;
    width: 57%;
    background: linear-gradient(90deg, rgba(223,248,255,.98) 0%, rgba(223,248,255,.9) 58%, rgba(223,248,255,0) 100%);
    pointer-events: none;
  }

  .hero-layout {
    position: relative;
    z-index: 4;
    display: grid;
    min-height: max(790px, 100svh);
    align-items: center;
    padding-top: calc(var(--header-height) + 54px);
    padding-bottom: 90px;
  }

  .hero-copy { width: min(54%, 720px); padding-top: 20px; }
  .hero-location { margin-bottom: 34px; color: rgba(4,71,142,.56); font-size: 10px; font-weight: 700; letter-spacing: .22em; }
  .hero-copy h1 { margin-bottom: 28px; font-family: "Noto Serif JP", serif; font-size: clamp(62px, 5.8vw, 92px); font-weight: 500; letter-spacing: -.075em; line-height: 1.24; }
  .hero-copy h1 span { display: block; }
  .hero-copy h1 span:last-child { white-space: nowrap; }
  .hero-lead { max-width: 570px; margin-bottom: 34px; color: rgba(4,42,83,.7); font-size: 14px; line-height: 2; }
  .mobile-hero-visual { display: none; }

  .hero-services { display: grid; width: min(100%, 560px); grid-template-columns: repeat(3, minmax(0,1fr)); gap: 14px; }
  .hero-services a {
    display: flex;
    min-height: 172px;
    flex-direction: column;
    justify-content: space-between;
    padding: 20px 18px 18px;
    border: 1px solid rgba(255,255,255,.82);
    border-radius: 46% 54% 45% 55% / 38% 40% 60% 62%;
    background: rgba(255,255,255,.62);
    box-shadow: inset 0 1px 0 rgba(255,255,255,.8), 0 18px 50px rgba(7,78,144,.06);
    backdrop-filter: blur(14px);
    transition: transform .25s ease, background .25s ease, box-shadow .25s ease;
  }
  .hero-services a:nth-child(2) { border-radius: 52% 48% 58% 42% / 44% 56% 44% 56%; }
  .hero-services a:nth-child(3) { border-radius: 44% 56% 48% 52% / 55% 42% 58% 45%; }
  .hero-services a:hover { background: rgba(255,255,255,.86); box-shadow: 0 24px 60px rgba(7,78,144,.12); transform: translateY(-7px); }
  .service-number { color: rgba(4,71,142,.52); font-size: 9px; font-weight: 700; letter-spacing: .14em; }
  .hero-services strong { align-self: center; font-family: "Noto Serif JP", serif; font-size: clamp(15px,1.35vw,20px); font-weight: 600; white-space: nowrap; }
  .hero-services i { display: grid; width: 32px; height: 32px; place-items: center; align-self: center; border-radius: 50%; color: white; background: var(--ocean); font-size: 14px; font-style: normal; }
  .hero-action { display: inline-flex; min-height: 54px; gap: 42px; align-items: center; margin-top: 30px; padding: 0 14px 0 24px; border-radius: 999px; color: white; background: var(--ocean); font-family: "Noto Serif JP", serif; font-size: 15px; font-weight: 600; letter-spacing: .04em; box-shadow: 0 16px 40px rgba(4,71,142,.18); transition: transform .2s ease, background .2s ease; }
  .hero-action:hover { background: #07376f; transform: translateY(-3px); }
  .hero-action span { display: grid; width: 34px; height: 34px; place-items: center; border-radius: 50%; color: var(--ocean); background: white; }

  .hero-collage { position: absolute; z-index: 1; inset: 0; pointer-events: none; }
  .hero-photo { position: absolute; overflow: hidden; background-repeat: no-repeat; background-size: cover; box-shadow: inset 0 0 0 1px rgba(255,255,255,.46); }
  .hero-photo::after { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(177,238,255,.08), rgba(4,71,142,.08)); content: ""; mix-blend-mode: color; }
  .hero-photo-city::before { position: absolute; z-index: 1; inset: 0 auto 0 0; width: 19%; background: linear-gradient(90deg, #c8f1ff 0%, rgba(200,241,255,.82) 38%, transparent 100%); content: ""; }
  .hero-photo-city { top: 10%; right: -5%; width: 56%; height: 34%; border-radius: 52% 0 0 50% / 72% 0 0 44%; background-image: url('/images/matsuyama-visual.webp'); background-position: 58% 48%; transform: rotate(-1.8deg); }
  .hero-photo-workshop { top: 39%; right: -6%; width: 55%; height: 39%; border-radius: 54% 0 0 48% / 50% 0 0 58%; background-image: url('/images/workshop-youth.webp'); background-position: 48% 48%; transform: rotate(1deg); }
  .hero-photo-coast { right: -5%; bottom: -8%; left: 7%; height: 34%; border-radius: 53% 47% 0 0 / 34% 44% 0 0; background-image: url('/images/setouchi-water.webp'); background-position: 50% 54%; transform: rotate(-1.5deg); opacity: .92; }
  .water-ribbon { position: absolute; display: block; border: 1px solid rgba(255,255,255,.62); border-radius: 50%; background: rgba(198,244,255,.17); box-shadow: inset 0 0 40px rgba(255,255,255,.2); backdrop-filter: blur(3px); }
  .ribbon-one { right: -9%; bottom: 9%; width: 112%; height: 26%; transform: rotate(5deg); }
  .ribbon-two { right: -18%; bottom: -2%; width: 82%; height: 18%; transform: rotate(-7deg); }

  .matsuyama-badge {
    position: absolute;
    z-index: 5;
    right: 4.5%;
    bottom: 8%;
    display: grid;
    width: clamp(130px, 12vw, 184px);
    aspect-ratio: 1;
    place-content: center;
    border: 1px solid rgba(255,255,255,.8);
    border-radius: 50%;
    color: var(--ocean);
    background: rgba(235,251,255,.72);
    box-shadow: inset 0 0 36px rgba(255,255,255,.72), 0 20px 70px rgba(4,71,142,.12);
    text-align: center;
    backdrop-filter: blur(15px);
  }
  .matsuyama-badge span { font-size: 8px; font-weight: 700; letter-spacing: .24em; }
  .matsuyama-badge strong { font-family: "Noto Serif JP", serif; font-size: clamp(30px,3vw,44px); font-weight: 500; letter-spacing: .06em; }

  .thought-section { padding: clamp(110px,14vw,210px) 0; background: var(--paper); }
  .thought-grid { display: grid; grid-template-columns: .28fr 1fr; gap: clamp(60px,10vw,160px); }
  .section-marker { display: flex; gap: 18px; align-items: flex-start; padding-top: 16px; border-top: 1px solid var(--line); color: var(--ocean); }
  .section-marker span { font-size: 12px; font-weight: 700; }
  .section-marker p { margin: 0; font-size: 9px; font-weight: 700; letter-spacing: .18em; }
  .jp-kicker { margin-bottom: 24px; color: var(--sea-700); font-family: "Noto Serif JP", serif; font-size: 18px; }
  .thought-copy h2,
  .water-heading h2,
  .proof-copy h2,
  .home-cta h2 { margin-bottom: 54px; font-size: clamp(52px,7.5vw,104px); font-weight: 500; letter-spacing: -.075em; line-height: 1.12; }
  .thought-copy h2 em,
  .water-heading h2 em,
  .proof-copy h2 em,
  .home-cta h2 em { color: var(--sea-600); font-family: "Noto Serif JP", serif; font-style: normal; font-weight: 500; }
  .thought-note { display: grid; grid-template-columns: 1fr auto; gap: 60px; align-items: end; max-width: 880px; margin-left: auto; }
  .thought-note p { margin: 0; color: var(--ink-600); line-height: 2.05; }
  .water-link { display: inline-flex; gap: 22px; align-items: center; padding-bottom: 8px; border-bottom: 1px solid currentColor; color: var(--ocean); font-size: 12px; font-weight: 700; white-space: nowrap; }
  .water-link span { transition: transform .2s ease; }
  .water-link:hover span { transform: translateX(5px); }

  .book-section { padding: clamp(100px,13vw,190px) 0; color: white; background: var(--ink); }
  .book-grid { display: grid; grid-template-columns: .28fr .72fr 1fr; gap: clamp(42px,6vw,96px); align-items: center; }
  .book-marker { align-self: stretch; color: var(--tide); border-color: var(--line-invert); }
  .book-visual { position: relative; display: grid; min-height: 590px; place-items: center; }
  .book-visual::before,
  .book-visual::after { position: absolute; border: 1px solid rgba(255,255,255,.12); border-radius: 50%; content: ""; }
  .book-visual::before { width: 118%; aspect-ratio: 1; }
  .book-visual::after { width: 88%; aspect-ratio: 1; border-color: rgba(116,220,246,.2); }
  .book-cover {
    position: relative;
    z-index: 1;
    display: block;
    width: min(100%,390px);
    height: auto;
    border: 1px solid rgba(255,255,255,.18);
    box-shadow: 24px 30px 70px rgba(0,0,0,.34);
    transform: rotate(-2.5deg);
  }
  .book-copy .jp-kicker { color: var(--tide); }
  .book-copy h2 { margin: 0 0 42px; font-size: clamp(52px,7vw,98px); font-weight: 500; letter-spacing: -.075em; line-height: 1.05; }
  .book-copy h2 em { color: var(--tide); font-family: "Noto Serif JP", serif; font-style: normal; font-weight: 500; }
  .book-name { margin: 0 0 8px; font-family: "Noto Serif JP", serif; font-size: clamp(20px,2.1vw,30px); font-weight: 600; }
  .book-subtitle { margin: 0 0 32px; color: rgba(255,255,255,.54); font-size: 12px; }
  .book-description { max-width: 620px; margin: 0 0 18px; color: rgba(255,255,255,.64); line-height: 2; }
  .book-author { margin: 0 0 34px; color: var(--foam); font-size: 11px; font-weight: 700; letter-spacing: .06em; }
  .book-link { display: inline-flex; min-height: 56px; gap: 28px; align-items: center; padding: 0 20px 0 24px; border: 1px solid rgba(255,255,255,.38); border-radius: 999px; font-size: 12px; font-weight: 700; transition: color .2s ease, background .2s ease, transform .2s ease; }
  .book-link:hover { color: var(--ocean); background: white; transform: translateY(-3px); }

  .services-section { padding: clamp(100px,12vw,180px) 0; background: var(--cloud); }
  .water-heading { display: grid; grid-template-columns: .28fr 1fr; gap: clamp(60px,10vw,160px); margin-bottom: 80px; }
  .water-heading > div { display: flex; gap: 18px; align-items: flex-start; padding-top: 16px; border-top: 1px solid var(--line); color: var(--ocean); }
  .water-heading > div span { font-size: 12px; font-weight: 700; }
  .water-heading > div p { margin: 0; font-size: 9px; font-weight: 700; letter-spacing: .18em; }
  .water-heading h2 { margin: 0; }
  .service-current { display: grid; grid-template-columns: repeat(3,minmax(0,1fr)); gap: 18px; }
  .service-card { display: flex; min-height: 500px; flex-direction: column; justify-content: space-between; overflow: hidden; padding: 28px; border: 1px solid rgba(255,255,255,.9); background: rgba(255,255,255,.74); box-shadow: 0 24px 80px rgba(4,71,142,.07); backdrop-filter: blur(8px); }
  .card-business { border-radius: 48% 16px 16px 16px / 25% 16px 16px 16px; }
  .card-training { border-radius: 16px 48% 16px 16px / 16px 24% 16px 16px; }
  .card-talent { border-radius: 16px 16px 52% 16px / 16px 16px 28% 16px; }
  .service-card-top { display: flex; align-items: center; justify-content: space-between; color: var(--sea-700); font-size: 9px; font-weight: 700; letter-spacing: .16em; }
  .service-card-top b { display: grid; width: 44px; height: 44px; place-items: center; border-radius: 50%; color: white; background: var(--sea-600); font-size: 11px; }
  .service-card h3 { margin-bottom: 18px; font-family: "Noto Serif JP", serif; font-size: clamp(28px,3vw,42px); font-weight: 600; letter-spacing: -.04em; }
  .service-card p { margin: 0; color: var(--ink-600); font-size: 13px; line-height: 2; }
  .service-card > a { display: flex; align-items: center; justify-content: space-between; padding-top: 18px; border-top: 1px solid var(--line); color: var(--ocean); font-size: 12px; font-weight: 700; }

  .proof-section { position: relative; overflow: hidden; padding: clamp(110px,14vw,200px) 0; color: white; background: var(--ocean); }
  .proof-water { position: absolute; inset: 0; opacity: .42; background: radial-gradient(circle at 22% 20%, rgba(109,224,255,.82), transparent 32%), radial-gradient(circle at 85% 80%, rgba(125,235,255,.38), transparent 35%); }
