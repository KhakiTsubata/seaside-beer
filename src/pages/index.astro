---
import { getCollection } from 'astro:content';
import { Image, Picture } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import hero from '../assets/brand/hero-seaside-full.png';
import corporateImage from '../assets/brand/feature-business.png';
import academyImage from '../assets/brand/feature-school.png';
import localImage from '../assets/brand/feature-local.png';

const insights = (await getCollection('insights', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);
const dateFormatter = new Intl.DateTimeFormat('ja-JP', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});
---

<BaseLayout image="/og.png">
  <section class="home-hero">
    <div class="hero-orbit hero-orbit-one" aria-hidden="true"></div>
    <div class="hero-orbit hero-orbit-two" aria-hidden="true"></div>
    <div class="container-wide hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">AI EDUCATION & IMPLEMENTATION / MATSUYAMA</p>
        <h1>AIを、<br /><span>現場で使える力</span>に。</h1>
        <p class="hero-lead">
          SeasideBeerは、松山を拠点に企業のAI導入を支え、
          若者が仕事につながる成果物をつくるところまで伴走します。
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href="/services/corporate/">
            企業向け支援を見る <span aria-hidden="true">→</span>
          </a>
          <a class="button button-ghost" href="/contact/">相談する</a>
        </div>
        <p class="hero-philosophy">
          <span>OUR PHILOSOPHY</span>{' '}
          AIに仕事を任せて、海辺でビールでも飲もう。
        </p>
      </div>

      <div class="hero-visual">
        <div class="hero-image-shell">
          <Picture
            src={hero}
            formats={['avif', 'webp']}
            widths={[640, 900, 1200]}
            sizes="(max-width: 860px) 100vw, 48vw"
            alt="瀬戸内の海辺でAIを使って働く人を描いたSeasideBeerのイラスト"
            loading="eager"
            fetchpriority="high"
          />
        </div>
        <div class="hero-note hero-note-top">
          <span>01</span>
          <p>企業の仕事へ<br />AIを実装する</p>
        </div>
        <div class="hero-note hero-note-bottom">
          <span>02</span>
          <p>若者の成果を<br />企業へつなぐ</p>
        </div>
      </div>
    </div>
  </section>

  <section class="signal-strip" aria-label="SeasideBeerの現在地">
    <div class="container-wide signal-grid">
      <div><strong>松山発</strong><span>地域企業と若者をAIでつなぐ</span></div>
      <div><strong>企業向け</strong><span>AI研修・導入・業務改善</span></div>
      <div><strong>人材育成</strong><span>企業に見せられる10人をつくる</span></div>
    </div>
  </section>

  <section class="section problem-section">
    <div class="container">
      <SectionHeading
        eyebrow="WHY SEASIDEBEER"
        title="ツールを入れただけでは、仕事は変わらない。"
        lead="生成AIの導入で難しいのは、登録や操作ではありません。どの仕事を任せ、誰が確認し、現場へどう残すか。SeasideBeerは、その設計と実装を一緒に進めます。"
      />
      <div class="card-grid problem-grid">
        <article class="card problem-card">
          <span class="card-number">01</span>
          <h3>仕事を切り分ける</h3>
          <p>「AIで何かする」から始めず、時間がかかる仕事、判断が必要な仕事、繰り返す仕事を整理します。</p>
        </article>
        <article class="card problem-card">
          <span class="card-number">02</span>
          <h3>小さく形にする</h3>
          <p>研修だけで終わらせず、資料、調査、文章、Web、社内手順など、実際に使えるものをつくります。</p>
        </article>
        <article class="card problem-card">
          <span class="card-number">03</span>
          <h3>人と手順を残す</h3>
          <p>担当者だけの技にしないために、再現できる手順、確認基準、次に改善する場所まで共有します。</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-cloud services-section">
    <div class="container-wide">
      <SectionHeading
        eyebrow="WHAT WE DO"
        title="企業の実装と、次の担い手を育てる。"
        lead="売上の入口は企業向け支援。長期の土台は若者の育成。二つを分けず、地域の中で仕事と学びが循環する形をつくります。"
      />

      <article class="service-feature service-corporate">
        <div class="service-copy">
          <p class="service-index">01 / FOR BUSINESS</p>
          <h3>企業向けAI研修・導入支援</h3>
          <p>
            経営者・管理職向けの体験会から、社員研修、業務ごとのAI導入、月次の改善支援まで。
            現場で一つ成果物が動くところを最初の区切りにします。
          </p>
          <ul class="service-tags" aria-label="企業向け支援の内容">
            <li>経営者・管理職向けAI体験</li>
            <li>社員向け実務研修</li>
            <li>業務改善・制作支援</li>
            <li>月額AI導入支援</li>
          </ul>
          <a class="text-link" href="/services/corporate/">支援内容を見る <span>→</span></a>
        </div>
        <div class="service-image">
          <Image src={corporateImage} alt="企業のAI活用を表すイラスト" widths={[480, 720]} loading="lazy" />
        </div>
      </article>

      <div class="service-secondary-grid">
        <article class="service-secondary">
          <div class="service-secondary-image">
            <Image src={academyImage} alt="若者向けAI講座を表すイラスト" widths={[280, 480]} loading="lazy" />
          </div>
          <p class="service-index">02 / FOR NEXT TALENT</p>
          <h3>AI人材育成</h3>
          <p>受講者数より、企業に見せられる完成物と説明力を優先します。4回の実践講座と成果発表を基本形にします。</p>
          <a class="text-link" href="/academy/">育成方針を見る <span>→</span></a>
        </article>
        <article class="service-secondary service-local">
          <div class="service-secondary-image">
            <Image src={localImage} alt="松山と地域連携を表すイラスト" widths={[280, 480]} loading="lazy" />
          </div>
          <p class="service-index">03 / FOR MATSUYAMA</p>
          <h3>大学・企業・地域の接続</h3>
          <p>講座や制作物を閉じず、企業、大学、行政、スポンサーへ見せられる場と次の仕事につなげます。</p>
          <a class="text-link" href="/about/">目指す地域像を見る <span>→</span></a>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-sea current-section">
    <div class="container-wide split current-grid">
      <div>
        <SectionHeading
          eyebrow="CURRENT WORK"
          title="いま公開できることを、正確に。"
          lead="大きく見せるための数字は置きません。現在進めている仕事と、次に証拠として残すものを明確にします。"
          invert={true}
        />
        <a class="button button-primary" href="/about/">現在地を詳しく見る</a>
      </div>
      <div class="current-list">
        <article>
          <span>01</span>
          <div>
            <h3>大学教員へのAI活用支援</h3>
            <p>松山の大学関係者へ、生成AIの使い方を個別に支援しています。固有名詞は許可が得られるまで公開しません。</p>
          </div>
        </article>
        <article>
          <span>02</span>
          <div>
            <h3>管理職向け生成AI書籍の執筆</h3>
            <p>AIを業務と組織へ導入する考え方を、非技術系の管理職へ伝える原稿を制作中です。</p>
          </div>
        </article>
        <article>
          <span>03</span>
          <div>
            <h3>企業に見せられる10人</h3>
            <p>HP、LP、ポートフォリオ、資料などを完成させ、自分で説明できる若者10人を最初の基準に置いています。</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section founder-section">
    <div class="container split">
      <div class="founder-copy prose-block">
        <p class="eyebrow">FOUNDER'S NOTE</p>
        <h2>AIで時間を取り戻し、地域で使う。</h2>
        <p>
          AI活用の目的を、作業を速くすることだけで終わらせたくありません。
          人が地域で会い、つくり、試し、仕事を生む時間を増やす。そのために企業の現場と若者の学びをつなぎます。
        </p>
        <a class="text-link" href="/about/">SeasideBeerについて <span>→</span></a>
      </div>
      <div class="quote-card">
        <blockquote>「松山でAIを学んだ人が、松山の会社の仕事を変える。その循環を、実物から始めます。」</blockquote>
        <cite>貝崎泰我 / SeasideBeer 代表</cite>
      </div>
    </div>
  </section>

  <section class="section section-cloud insights-section">
    <div class="container-wide">
      <div class="insights-header">
        <SectionHeading
          eyebrow="INSIGHTS"
          title="AIを仕事に移すための記録。"
          lead="一般論を並べず、企業導入、研修設計、人材育成で実際に判断が必要になる論点を書きます。"
        />
        <a class="text-link" href="/insights/">すべての記事 <span>→</span></a>
      </div>
      <div class="insight-grid">
        {insights.map((entry, index) => (
          <article class:list={['insight-card', { featured: index === 0 }]}>
            <a href={`/insights/${entry.id}/`}>
              <div class="insight-meta">
                <span>{entry.data.category}</span>
                <time datetime={entry.data.publishedAt.toISOString()}>{dateFormatter.format(entry.data.publishedAt)}</time>
              </div>
              <h3>{entry.data.title}</h3>
              <p>{entry.data.description}</p>
              <span class="insight-arrow" aria-hidden="true">↗</span>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-compact">
    <div class="container-wide cta-panel">
      <p class="eyebrow">START A CONVERSATION</p>
      <h2>「うちの仕事なら何ができる？」からで大丈夫です。</h2>
      <p>対象となる仕事と今の困りごとを伺い、研修が先か、小さな制作が先か、進め方を整理します。</p>
      <a class="button button-dark" href="/contact/">相談内容を送る <span aria-hidden="true">→</span></a>
    </div>
  </section>
</BaseLayout>

<style>
  .home-hero {
    position: relative;
    overflow: hidden;
    padding: 86px 0 92px;
    background:
      radial-gradient(circle at 9% 16%, rgba(168, 232, 243, 0.48), transparent 26%),
      linear-gradient(135deg, #f7fcfd 0%, #ffffff 58%, #fff7dc 135%);
  }

  .hero-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 0.94fr) minmax(480px, 1.06fr);
    gap: clamp(48px, 7vw, 96px);
    align-items: center;
  }

  .hero-copy h1 {
    max-width: 690px;
    margin-bottom: 28px;
    font-size: clamp(56px, 7.5vw, 94px);
    font-weight: 900;
    letter-spacing: -0.082em;
    line-height: 1.06;
  }

  .hero-copy h1 span {
    color: var(--sea-700);
  }

  .hero-lead {
    max-width: 620px;
    margin-bottom: 34px;
    color: var(--ink-600);
    font-size: clamp(16px, 1.7vw, 19px);
    line-height: 2;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .hero-philosophy {
    display: flex;
    gap: 12px;
    align-items: center;
    margin: 34px 0 0;
    color: var(--ink-700);
    font-size: 12px;
    font-weight: 700;
  }

  .hero-philosophy span {
    color: var(--sea-700);
    font-size: 9px;
    letter-spacing: 0.16em;
  }

  .hero-visual {
    position: relative;
    min-width: 0;
    padding: 20px 22px 34px 0;
  }

  .hero-image-shell {
    height: min(660px, 62vw);
    min-height: 520px;
    overflow: hidden;
    border: 10px solid white;
    border-radius: 180px 180px 32px 180px;
    background: var(--sea-100);
    box-shadow: var(--shadow-lg);
  }

  .hero-image-shell :global(picture),
  .hero-image-shell :global(img) {
    width: 100%;
    height: 100%;
  }

  .hero-image-shell :global(img) {
    object-fit: cover;
    object-position: 86% center;
  }

  .hero-note {
    position: absolute;
    display: flex;
    gap: 12px;
    align-items: center;
    padding: 14px 18px;
    border: 1px solid rgba(217, 232, 236, 0.92);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.94);
    box-shadow: var(--shadow-sm);
  }

  .hero-note span {
    display: grid;
    width: 32px;
    height: 32px;
    place-items: center;
    border-radius: 50%;
    color: var(--ink-950);
    background: var(--sun-400);
    font-size: 10px;
    font-weight: 850;
  }

  .hero-note p {
    margin: 0;
    color: var(--ink-900);
    font-size: 12px;
    font-weight: 800;
    line-height: 1.55;
  }

  .hero-note-top {
    top: 88px;
    right: -8px;
  }

  .hero-note-bottom {
    bottom: 0;
    left: -30px;
  }

  .hero-orbit {
    position: absolute;
    border: 1px solid rgba(0, 153, 189, 0.13);
    border-radius: 50%;
  }

  .hero-orbit-one {
    top: -420px;
    right: -320px;
    width: 900px;
    height: 900px;
  }

  .hero-orbit-two {
    bottom: -240px;
    left: -270px;
    width: 560px;
    height: 560px;
  }

  .signal-strip {
    color: white;
    background: var(--ink-950);
  }

  .signal-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  .signal-grid > div {
    display: flex;
    gap: 14px;
    align-items: baseline;
    min-height: 94px;
    padding: 28px 34px;
    border-right: 1px solid rgba(255, 255, 255, 0.12);
  }

  .signal-grid > div:first-child {
    border-left: 1px solid rgba(255, 255, 255, 0.12);
  }

  .signal-grid strong {
    flex: 0 0 auto;
    color: var(--sun-400);
    font-size: 13px;
  }

  .signal-grid span {
    color: rgba(255, 255, 255, 0.68);
    font-size: 12px;
  }

  .problem-section {
    position: relative;
  }

  .problem-grid {
    counter-reset: problem;
  }

  .problem-card {
    min-height: 280px;
  }

  .service-feature {
    display: grid;
    grid-template-columns: 1.25fr 0.75fr;
    gap: 52px;
    align-items: center;
    margin-bottom: 24px;
    padding: clamp(36px, 6vw, 66px);
    border-radius: var(--radius-lg);
    color: white;
    background: linear-gradient(135deg, var(--ink-950), #0d5c73);
    box-shadow: var(--shadow-lg);
  }

  .service-index {
    margin-bottom: 14px;
    color: var(--sea-200);
    font-size: 10px;
    font-weight: 850;
    letter-spacing: 0.16em;
  }

  .service-feature h3,
  .service-secondary h3 {
    margin-bottom: 18px;
    font-size: clamp(28px, 4vw, 46px);
    letter-spacing: -0.05em;
    line-height: 1.3;
  }

  .service-feature p:not(.service-index) {
    max-width: 620px;
    color: rgba(255, 255, 255, 0.72);
  }

  .service-feature .text-link {
    color: white;
  }

  .service-feature .text-link span {
    color: var(--sun-400);
  }

  .service-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    padding: 0;
    list-style: none;
  }

  .service-tags li {
    padding: 7px 11px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    color: rgba(255, 255, 255, 0.82);
    font-size: 11px;
  }

  .service-image {
    display: grid;
    min-height: 330px;
    place-items: center;
    overflow: hidden;
    border-radius: 50% 50% 22px 50%;
    background: var(--sea-100);
  }

  .service-image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .service-secondary-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .service-secondary {
    position: relative;
    overflow: hidden;
    padding: 42px;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: white;
  }

  .service-secondary-image {
    float: right;
    width: 144px;
    height: 144px;
    margin: -8px -8px 18px 24px;
    overflow: hidden;
    border-radius: 34px;
  }

  .service-secondary-image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .service-secondary .service-index {
    color: var(--sea-700);
  }

  .service-secondary h3 {
    font-size: 30px;
  }

  .service-secondary p:not(.service-index) {
    color: var(--ink-600);
    font-size: 14px;
  }

  .current-section {
    position: relative;
    overflow: hidden;
  }

  .current-list {
    display: grid;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
  }

  .current-list article {
    display: grid;
    grid-template-columns: 42px 1fr;
    gap: 20px;
    padding: 28px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
  }

  .current-list > article > span {
    color: var(--sun-400);
    font-size: 11px;
    font-weight: 850;
  }

  .current-list h3 {
    margin-bottom: 8px;
    color: white;
    font-size: 19px;
  }

  .current-list p {
    margin: 0;
    color: rgba(255, 255, 255, 0.62);
    font-size: 13px;
  }

  .founder-copy p:not(.eyebrow) {
    margin-bottom: 24px;
  }

  .insights-header {
    display: flex;
    gap: 32px;
    align-items: flex-end;
    justify-content: space-between;
  }

  .insight-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .insight-card a {
    position: relative;
    display: flex;
    min-height: 340px;
    flex-direction: column;
    padding: 30px;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: white;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .insight-card a:hover {
    border-color: var(--sea-200);
    box-shadow: var(--shadow-sm);
    transform: translateY(-5px);
  }

  .insight-meta {
    display: flex;
    justify-content: space-between;
    margin-bottom: 42px;
    color: var(--ink-500);
    font-size: 10px;
    font-weight: 750;
  }

  .insight-meta span {
    color: var(--sea-700);
  }

  .insight-card h3 {
    margin-bottom: 14px;
    font-size: 21px;
    letter-spacing: -0.035em;
    line-height: 1.55;
  }

  .insight-card p {
    margin-bottom: 28px;
    color: var(--ink-600);
    font-size: 13px;
  }

  .insight-arrow {
    display: grid;
    width: 38px;
    height: 38px;
    place-items: center;
    margin-top: auto;
    border-radius: 50%;
    color: white;
    background: var(--ink-950);
  }

  @media (max-width: 1080px) {
    .hero-grid {
      grid-template-columns: 1fr 0.9fr;
    }

    .hero-image-shell {
      min-height: 500px;
    }

    .service-feature {
      grid-template-columns: 1fr 0.6fr;
    }
  }

  @media (max-width: 860px) {
    .home-hero {
      padding: 68px 0 74px;
    }

    .hero-grid {
      grid-template-columns: 1fr;
    }

    .hero-copy h1 {
      font-size: clamp(54px, 13vw, 78px);
    }

    .hero-visual {
      width: min(100%, 680px);
      margin-inline: auto;
    }

    .hero-image-shell {
      height: min(620px, 110vw);
    }

    .signal-grid {
      grid-template-columns: 1fr;
      padding-block: 8px;
    }

    .signal-grid > div,
    .signal-grid > div:first-child {
      min-height: auto;
      padding: 18px 0;
      border-right: 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.12);
      border-left: 0;
    }

    .signal-grid > div:last-child {
      border-bottom: 0;
    }

    .service-feature {
      grid-template-columns: 1fr;
    }

    .service-image {
      min-height: 300px;
    }

    .service-secondary-grid,
    .insight-grid {
      grid-template-columns: 1fr;
    }

    .insight-card a {
      min-height: 280px;
    }
  }

  @media (max-width: 680px) {
    .hero-copy h1 {
      font-size: clamp(48px, 14vw, 64px);
    }

    .hero-lead {
      font-size: 15px;
    }

    .hero-actions,
    .hero-actions .button {
      width: 100%;
    }

    .hero-philosophy {
      display: block;
      line-height: 1.8;
    }

    .hero-philosophy span {
      display: block;
    }

