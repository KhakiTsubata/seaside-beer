---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const insights = (await getCollection('insights', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);
const dateFormatter = new Intl.DateTimeFormat('ja-JP', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});
---

<BaseLayout image="/og.png">
  <section class="home-hero" aria-labelledby="home-title">
    <canvas class="tide-canvas" data-tide-canvas aria-hidden="true"></canvas>
    <div class="hero-sun" aria-hidden="true"><i></i></div>
    <div class="hero-grid" aria-hidden="true"></div>

    <div class="container-wide hero-inner">
      <div class="hero-topline">
        <p>AI IMPLEMENTATION / TALENT DEVELOPMENT</p>
        <p>MATSUYAMA — EHIME</p>
      </div>

      <div class="hero-copy">
        <p class="hero-kicker">MAKE WORK MOVE.</p>
        <h1 id="home-title">
          <span>仕事を、</span>
          <em>AIに渡す。</em>
        </h1>
        <div class="hero-bottom">
          <p>
            人間の時間を、地域に返す。<br />
            SeasideBeerは、松山から仕事の流れを変えるAI実装チームです。
          </p>
          <div class="hero-actions">
            <a class="button button-primary" href="/contact/">プロジェクトを相談する <span aria-hidden="true">↗</span></a>
            <a class="button button-ghost" href="#mission">私たちの考え方</a>
          </div>
        </div>
      </div>

      <div class="hero-rail" aria-label="SeasideBeerの事業領域">
        <span>01 / BUSINESS</span><strong>AI導入・研修</strong>
        <span>02 / TALENT</span><strong>AI人材育成</strong>
        <span>03 / CITY</span><strong>地域の接続</strong>
      </div>
    </div>
  </section>

  <section class="manifesto" id="mission">
    <div class="container-wide manifesto-grid">
      <div class="manifesto-label" data-reveal>
        <p>OUR POINT OF VIEW</p>
        <span>AI × WORK × MATSUYAMA</span>
      </div>
      <div class="manifesto-copy" data-reveal>
        <h2>変えるのは、<br />AIではない。<br /><em>仕事の流れだ。</em></h2>
        <div class="manifesto-note">
          <p>
            ツールを入れただけでは、仕事は変わりません。どの作業を任せ、誰が確認し、何を成果として残すのか。
            SeasideBeerは研修、設計、制作、改善までを一つの流れとして実装します。
          </p>
          <a class="text-link" href="/about/">思想と現在地 <span>↗</span></a>
        </div>
      </div>
    </div>
  </section>

  <section class="work-section">
    <div class="container-wide">
      <header class="work-header" data-reveal>
        <div>
          <p class="section-index">01 / FOR BUSINESS</p>
          <h2>一つの仕事を、<br /><em>本当に減らす。</em></h2>
        </div>
        <p>
          経営者・管理職向けの体験から、社員研修、業務ごとのAI導入、月次改善まで。
          一般論ではなく、実際の仕事と成果物を題材に進めます。
        </p>
      </header>

      <div class="work-stage" data-reveal>
        <div class="work-stage-head">
          <span>WORKFLOW / 001</span>
          <span>LIVE SYSTEM</span>
        </div>
        <div class="work-process">
          <article>
            <span>DISCOVER</span>
            <strong>任せる仕事を決める</strong>
            <p>時間、頻度、判断の重さから対象業務を選ぶ。</p>
          </article>
          <i aria-hidden="true"></i>
          <article>
            <span>BUILD</span>
            <strong>小さく実装する</strong>
            <p>資料、調査、文章、Web、社内手順を形にする。</p>
          </article>
          <i aria-hidden="true"></i>
          <article>
            <span>OPERATE</span>
            <strong>現場で使い続ける</strong>
            <p>確認基準と改善手順を残し、個人技にしない。</p>
          </article>
        </div>
        <a class="stage-link" href="/services/corporate/"><span>企業向け支援を見る</span><b aria-hidden="true">↗</b></a>
      </div>
    </div>
  </section>

  <section class="talent-section">
    <div class="talent-orbit" aria-hidden="true"><i></i><i></i><i></i></div>
    <div class="container-wide talent-grid">
      <div class="talent-number" data-reveal>
        <span>FIRST MILESTONE</span>
        <strong>10</strong>
        <small>PEOPLE WITH PROOF</small>
      </div>
      <div class="talent-copy" data-reveal>
        <p class="section-index">02 / FOR TALENT</p>
        <h2>「学んだ人」ではなく、<br /><em>見せられる人</em>を。</h2>
        <p>
          最初の目標は、企業に見せられる成果物を持つ10人です。
          4回の実践講座で、作る、直す、説明する、外へ見せるところまで進めます。
        </p>
        <ol class="talent-steps">
          <li><span>01</span>課題を選ぶ</li>
          <li><span>02</span>AIと作る</li>
          <li><span>03</span>人が直す</li>
          <li><span>04</span>企業へ見せる</li>
        </ol>
        <a class="button button-primary" href="/academy/">人材育成を見る <span aria-hidden="true">↗</span></a>
      </div>
    </div>
  </section>

  <section class="city-section">
    <div class="container-wide city-grid">
      <header data-reveal>
        <p class="section-index">03 / FOR THE CITY</p>
        <h2>人と仕事が、<br />松山で<em>循環する。</em></h2>
        <p>
          企業の課題を学びの題材へ。若者の成果を次の仕事へ。
          企業、大学、行政、支援者が一度きりで終わらない接点をつくります。
        </p>
      </header>
      <div class="city-system" data-reveal aria-label="地域循環の構想図">
        <div class="city-ring ring-one"></div>
        <div class="city-ring ring-two"></div>
        <div class="city-core"><span>MATSUYAMA</span><strong>SEASIDE<br />BEER</strong></div>
        <div class="city-node node-business"><span>01</span><strong>LOCAL<br />BUSINESS</strong></div>
        <div class="city-node node-talent"><span>02</span><strong>YOUNG<br />TALENT</strong></div>
        <div class="city-node node-partner"><span>03</span><strong>UNIVERSITY<br />& CITY</strong></div>
      </div>
    </div>
  </section>

  <section class="now-section">
    <div class="container-wide now-grid">
      <div class="now-title" data-reveal>
        <p class="section-index">NOW / 2026</p>
        <h2>大きく見せず、<br />前進を見せる。</h2>
      </div>
      <div class="now-list" data-reveal>
        <article><span>PRIORITY</span><strong>企業向けAI研修・導入支援</strong><p>初期売上と現場の実績づくりを最優先に進めています。</p></article>
        <article><span>IN PROGRESS</span><strong>松山の大学関係者への個別支援</strong><p>生成AIを仕事へ取り込むための支援を実施しています。</p></article>
        <article><span>BUILDING</span><strong>法人化と最初の育成プログラム</strong><p>実績と運営体制を整えながら、段階的に公開します。</p></article>
      </div>
    </div>
  </section>

  <section class="journal-section">
    <div class="container-wide">
      <header class="journal-head" data-reveal>
        <div><p class="section-index">JOURNAL</p><h2>考えたことを、<br />仕事へ返す。</h2></div>
        <a class="text-link" href="/insights/">すべての記事 <span>↗</span></a>
      </header>
      <div class="journal-list">
        {insights.map((entry, index) => (
          <a class="journal-item" href={`/insights/${entry.id}/`} data-reveal>
            <span class="journal-no">0{index + 1}</span>
            <div class="journal-meta"><span>{entry.data.category}</span><time datetime={entry.data.publishedAt.toISOString()}>{dateFormatter.format(entry.data.publishedAt)}</time></div>
            <h3>{entry.data.title}</h3>
            <span class="journal-arrow" aria-hidden="true">↗</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="home-cta">
    <div class="container-wide home-cta-inner" data-reveal>
      <p>START SMALL. MOVE REAL WORK.</p>
      <h2>まず、一つの仕事から。</h2>
      <a class="button button-primary" href="/contact/">相談内容を送る <span aria-hidden="true">↗</span></a>
    </div>
  </section>
</BaseLayout>

<style>
  .home-hero {
    position: relative;
    min-height: 100svh;
    overflow: hidden;
    color: white;
    background: var(--ink);
  }

  .tide-canvas,
  .hero-grid,
  .hero-sun { position: absolute; inset: 0; }

  .tide-canvas { z-index: 1; width: 100%; height: 100%; opacity: .88; }
  .hero-grid {
    z-index: 0;
    background-image: linear-gradient(rgba(255,255,255,.035) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.035) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: linear-gradient(to right, transparent 0, black 50%, black 100%);
  }

  .hero-sun { z-index: 0; pointer-events: none; }
  .hero-sun::before {
    position: absolute;
    top: 13%;
    right: 3%;
    width: min(48vw, 700px);
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(circle at 38% 35%, #ff9a69 0, var(--sunset) 18%, #264fee 53%, rgba(7,19,31,0) 72%);
    filter: saturate(115%);
    content: "";
    animation: sun-breathe 10s ease-in-out infinite alternate;
  }

  .hero-sun i {
    position: absolute;
    top: 20%;
    right: 9%;
    width: min(35vw, 500px);
    aspect-ratio: 1;
    border: 1px solid rgba(255,255,255,.24);
    border-radius: 50%;
    box-shadow: 0 0 0 70px rgba(255,255,255,.025), 0 0 0 140px rgba(255,255,255,.018);
  }

  @keyframes sun-breathe { to { transform: translate(-2%, 3%) scale(1.04); } }

  .hero-inner {
    position: relative;
    z-index: 2;
    display: grid;
    min-height: 100svh;
    grid-template-rows: auto 1fr auto;
    padding-top: calc(var(--header-height) + 28px);
  }

  .hero-topline { display: flex; justify-content: space-between; color: rgba(255,255,255,.42); font-size: 9px; font-weight: 600; letter-spacing: .18em; }
  .hero-copy { align-self: center; width: min(100%, 1160px); padding: clamp(62px, 10vh, 110px) 0 54px; }
  .hero-kicker { margin-bottom: 28px; color: var(--tide); font-size: 10px; font-weight: 700; letter-spacing: .24em; }
  .hero-copy h1 { margin-bottom: 44px; font-size: clamp(78px, 12.6vw, 184px); font-weight: 500; letter-spacing: -.095em; line-height: .84; }
  .hero-copy h1 span,
  .hero-copy h1 em { display: block; }
  .hero-copy h1 em { margin-left: .42em; color: var(--tide); font-family: "Noto Serif JP", serif; font-style: normal; font-weight: 500; }
  .hero-bottom { display: flex; gap: 50px; align-items: flex-end; justify-content: space-between; margin-left: 7%; }
  .hero-bottom > p { max-width: 520px; margin: 0; color: rgba(255,255,255,.67); font-size: clamp(14px,1.4vw,17px); line-height: 2; }
  .hero-actions { display: flex; flex: 0 0 auto; gap: 10px; }
  .hero-rail { display: grid; grid-template-columns: auto 1fr auto 1fr auto 1fr; gap: 14px; align-items: center; padding: 24px 0; border-top: 1px solid var(--line-invert); color: rgba(255,255,255,.36); font-size: 8px; letter-spacing: .13em; }
  .hero-rail strong { color: white; font-size: 10px; letter-spacing: .04em; }

  .manifesto { padding: clamp(120px, 15vw, 220px) 0; background: var(--bone); }
  .manifesto-grid { display: grid; grid-template-columns: .38fr 1fr; gap: clamp(48px, 8vw, 140px); }
  .manifesto-label p,
  .section-index { margin-bottom: 10px; color: var(--blue); font-size: 9px; font-weight: 700; letter-spacing: .2em; }
  .manifesto-label span { color: var(--muted); font-size: 9px; letter-spacing: .14em; }
  .manifesto-copy h2 { margin-bottom: 70px; font-size: clamp(56px, 9vw, 126px); font-weight: 500; letter-spacing: -.09em; line-height: .98; }
  .manifesto-copy h2 em { color: var(--blue); font-family: "Noto Serif JP", serif; font-style: normal; font-weight: 500; }
  .manifesto-note { display: grid; grid-template-columns: 1fr auto; gap: 50px; align-items: end; max-width: 850px; margin-left: auto; }
  .manifesto-note p { margin: 0; color: var(--ink-600); line-height: 2; }

  .work-section { padding: clamp(110px, 13vw, 190px) 0; background: var(--paper); }
  .work-header { display: grid; grid-template-columns: 1.25fr .75fr; gap: 80px; align-items: end; margin-bottom: 82px; }
  .work-header h2,
  .talent-copy h2,
  .city-grid header h2,
  .now-title h2,
  .journal-head h2 { margin: 0; font-size: clamp(48px, 7.5vw, 108px); font-weight: 500; letter-spacing: -.085em; line-height: 1; }
  .work-header h2 em,
  .talent-copy h2 em,
  .city-grid header h2 em { color: var(--blue); font-family: "Noto Serif JP", serif; font-style: normal; font-weight: 500; }
  .work-header > p { max-width: 520px; margin: 0; color: var(--ink-600); line-height: 2; }
  .work-stage { color: white; background: var(--ink); }
  .work-stage-head { display: flex; justify-content: space-between; padding: 18px 22px; border-bottom: 1px solid var(--line-invert); color: rgba(255,255,255,.4); font-size: 8px; letter-spacing: .18em; }
  .work-process { display: grid; grid-template-columns: 1fr auto 1fr auto 1fr; min-height: 400px; align-items: stretch; }
  .work-process article { display: flex; flex-direction: column; justify-content: flex-end; padding: 48px 38px; }
  .work-process article > span { margin-bottom: auto; color: var(--tide); font-size: 9px; font-weight: 700; letter-spacing: .16em; }
  .work-process strong { margin-bottom: 16px; font-size: clamp(20px,2vw,28px); letter-spacing: -.04em; }
  .work-process p { margin: 0; color: rgba(255,255,255,.48); font-size: 12px; line-height: 1.9; }
  .work-process i { width: 1px; background: var(--line-invert); }
  .stage-link { display: flex; align-items: center; justify-content: space-between; padding: 22px; color: var(--ink); background: var(--tide); font-size: 11px; font-weight: 700; }
  .stage-link b { font-size: 24px; font-weight: 400; transition: transform .2s ease; }
  .stage-link:hover b { transform: translate(5px,-5px); }

  .talent-section { position: relative; overflow: hidden; padding: clamp(110px,14vw,200px) 0; color: white; background: var(--blue); }
  .talent-grid { display: grid; grid-template-columns: .82fr 1.18fr; gap: clamp(60px,9vw,150px); align-items: center; }
  .talent-number { position: relative; z-index: 1; }
  .talent-number > span,
  .talent-number small { display: block; color: var(--tide); font-size: 9px; font-weight: 700; letter-spacing: .18em; }
  .talent-number strong { display: block; margin: -18px 0 -8px; font-size: clamp(180px,28vw,410px); font-weight: 500; letter-spacing: -.13em; line-height: 1; }
  .talent-copy { position: relative; z-index: 1; }
  .talent-copy .section-index { color: var(--tide); }
  .talent-copy h2 em { color: var(--tide); }
  .talent-copy > p:not(.section-index) { max-width: 600px; margin: 34px 0 46px; color: rgba(255,255,255,.66); line-height: 2; }
  .talent-steps { display: grid; grid-template-columns: repeat(2,1fr); margin: 0 0 44px; padding: 0; border-top: 1px solid rgba(255,255,255,.24); list-style: none; }
  .talent-steps li { padding: 16px 0; border-bottom: 1px solid rgba(255,255,255,.24); font-size: 12px; }
  .talent-steps li:nth-child(odd) { border-right: 1px solid rgba(255,255,255,.24); }
  .talent-steps li:nth-child(even) { padding-left: 18px; }
  .talent-steps span { margin-right: 18px; color: var(--tide); font-size: 9px; }
  .talent-orbit { position: absolute; inset: 0; pointer-events: none; }
  .talent-orbit i { position: absolute; top: 50%; left: 21%; width: 38vw; aspect-ratio: 1; border: 1px solid rgba(255,255,255,.12); border-radius: 50%; transform: translate(-50%,-50%); }
  .talent-orbit i:nth-child(2) { width: 52vw; }
  .talent-orbit i:nth-child(3) { width: 66vw; }

  .city-section { padding: clamp(110px,14vw,210px) 0; background: var(--bone); }
  .city-grid { display: grid; grid-template-columns: .8fr 1.2fr; gap: clamp(50px,8vw,120px); align-items: center; }
  .city-grid header h2 em { display: inline-block; }
  .city-grid header > p:not(.section-index) { max-width: 530px; margin: 38px 0 0; color: var(--ink-600); line-height: 2; }
  .city-system { position: relative; aspect-ratio: 1.15; }
  .city-ring { position: absolute; top: 50%; left: 50%; border: 1px solid rgba(32,87,245,.22); border-radius: 50%; transform: translate(-50%,-50%); }
  .ring-one { width: 68%; aspect-ratio: 1; }
  .ring-two { width: 100%; aspect-ratio: 1; }
  .city-core,
  .city-node { position: absolute; display: grid; place-content: center; border-radius: 50%; text-align: center; }
  .city-core { top: 50%; left: 50%; width: 34%; aspect-ratio: 1; color: white; background: var(--blue); transform: translate(-50%,-50%); }
  .city-core span { margin-bottom: 7px; color: var(--tide); font-size: 7px; letter-spacing: .14em; }
  .city-core strong { font-size: clamp(16px,2.3vw,32px); letter-spacing: -.05em; line-height: .9; }
  .city-node { width: 24%; aspect-ratio: 1; border: 1px solid var(--line); background: var(--paper); }
  .city-node span { margin-bottom: 8px; color: var(--blue); font-size: 8px; }
  .city-node strong { font-size: clamp(9px,1vw,13px); line-height: 1.25; }
  .node-business { top: 2%; left: 38%; }
  .node-talent { right: 2%; bottom: 14%; }
  .node-partner { bottom: 7%; left: 2%; }

  .now-section { padding: clamp(100px,13vw,180px) 0; color: white; background: var(--ink); }
  .now-grid { display: grid; grid-template-columns: .78fr 1.22fr; gap: clamp(70px,11vw,170px); }
  .now-title .section-index { color: var(--tide); }
  .now-list { border-top: 1px solid var(--line-invert); }
  .now-list article { display: grid; grid-template-columns: 130px 1fr; gap: 12px 32px; padding: 30px 0; border-bottom: 1px solid var(--line-invert); }
  .now-list span { color: var(--tide); font-size: 8px; font-weight: 700; letter-spacing: .15em; }
  .now-list strong { font-size: 18px; font-weight: 600; letter-spacing: -.03em; }
  .now-list p { grid-column: 2; margin: 0; color: rgba(255,255,255,.48); font-size: 12px; }

  .journal-section { padding: clamp(100px,13vw,180px) 0; background: var(--paper); }
  .journal-head { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 70px; }
  .journal-list { border-top: 1px solid var(--line); }
  .journal-item { display: grid; grid-template-columns: 60px 180px 1fr 40px; gap: 24px; align-items: center; padding: 30px 0; border-bottom: 1px solid var(--line); transition: padding .25s ease, color .25s ease; }
  .journal-item:hover { padding-right: 14px; padding-left: 14px; color: var(--blue); }
  .journal-no { color: var(--blue); font-size: 10px; }
  .journal-meta { display: grid; gap: 4px; color: var(--muted); font-size: 9px; letter-spacing: .08em; }
  .journal-meta span { color: var(--blue); font-weight: 700; }
  .journal-item h3 { margin: 0; font-size: clamp(18px,2.2vw,30px); font-weight: 500; letter-spacing: -.04em; }
  .journal-arrow { font-size: 25px; }

  .home-cta { padding: clamp(86px,10vw,130px) 0; color: var(--ink); background: var(--tide); }
  .home-cta-inner { display: grid; grid-template-columns: 1fr auto; gap: 40px; align-items: end; }
  .home-cta p { grid-column: 1 / -1; margin: 0; font-size: 9px; font-weight: 700; letter-spacing: .2em; }
  .home-cta h2 { margin: 0; font-size: clamp(54px,9vw,126px); font-weight: 500; letter-spacing: -.09em; line-height: .94; }
  .home-cta .button { border-color: var(--ink); background: var(--ink); color: white; }

  @media (max-width: 980px) {
    .hero-bottom,
    .work-header,
    .talent-grid,
    .city-grid,
    .now-grid { grid-template-columns: 1fr; }
    .hero-bottom { display: grid; margin-left: 0; }
    .hero-actions { justify-self: start; }
    .hero-rail { grid-template-columns: auto 1fr; }
    .manifesto-grid { grid-template-columns: 1fr; }
    .manifesto-copy h2 { margin-bottom: 48px; }
    .work-process { grid-template-columns: 1fr; }
    .work-process i { width: auto; height: 1px; }
    .work-process article { min-height: 230px; }
    .talent-number { text-align: center; }
    .talent-number strong { font-size: min(58vw,390px); }
    .city-system { max-width: 760px; width: 100%; margin-inline: auto; }
  }

  @media (max-width: 680px) {
    .hero-inner { padding-top: calc(var(--header-height) + 18px); }
    .hero-topline p:last-child { display: none; }
    .hero-copy { padding: 72px 0 40px; }
    .hero-copy h1 { margin-bottom: 38px; font-size: clamp(68px,20vw,82px); line-height: .9; }
    .hero-copy h1 em { margin-left: 0; font-size: .78em; white-space: nowrap; }
    .hero-actions { width: 100%; flex-direction: column; }
    .hero-actions .button { width: 100%; }
    .hero-rail { padding: 18px 0; }
    .hero-sun::before { top: 18%; right: -38%; width: 105vw; opacity: .68; }
    .hero-sun i { top: 26%; right: -17%; width: 76vw; }
    .manifesto { padding: 96px 0; }
    .manifesto-copy h2 { font-size: clamp(54px,17vw,84px); }
    .manifesto-note { grid-template-columns: 1fr; gap: 32px; }
    .work-header { gap: 34px; margin-bottom: 48px; }
    .work-process article { min-height: 215px; padding: 32px 24px; }
