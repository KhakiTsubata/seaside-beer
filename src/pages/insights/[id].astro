---
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('insights', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'insights'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const dateFormatter = new Intl.DateTimeFormat('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={`${entry.data.title}｜SeasideBeer`}
  description={entry.data.description}
  image="/og.png"
  article={true}
  publishedAt={entry.data.publishedAt}
>
  <article>
    <header class="article-hero">
      <div class="container article-head-inner">
        <nav class="breadcrumbs" aria-label="パンくずリスト">
          <a href="/">トップ</a><span aria-hidden="true">/</span><a href="/insights/">記事・活動</a>
        </nav>
        <div class="article-kicker">
          <span>{entry.data.category}</span>
          <time datetime={entry.data.publishedAt.toISOString()}>{dateFormatter.format(entry.data.publishedAt)}</time>
        </div>
        <h1>{entry.data.title}</h1>
        <p class="article-description">{entry.data.description}</p>
        <p class="article-audience">想定読者：{entry.data.audience}</p>
      </div>
    </header>

    <div class="container article-layout">
      <div class="article-body">
        <Content />
      </div>
      <aside class="article-aside">
        <div>
          <span>WRITTEN BY</span>
          <strong>SeasideBeer</strong>
          <p>松山で企業のAI導入と若者のAI人材育成を進めています。</p>
        </div>
        <a class="text-link" href="/contact/">この記事について相談 <span>→</span></a>
      </aside>
    </div>

    <footer class="article-end section-compact">
      <div class="container article-end-inner">
        <div>
          <p class="eyebrow">NEXT STEP</p>
          <h2>自社の仕事へ置き換えて考える。</h2>
          <p>一般論のままでは進みません。対象となる仕事を一つ挙げていただければ、次に整理する点を一緒に考えます。</p>
        </div>
        <a class="button button-dark" href="/contact/">相談する <span aria-hidden="true">→</span></a>
      </div>
    </footer>
  </article>
</BaseLayout>

<style>
  .article-hero {
    position: relative;
    overflow: hidden;
    padding: calc(var(--header-height) + 72px) 0 88px;
    background: linear-gradient(135deg, var(--sea-50), white 66%, #fff1eb);
  }

  .article-head-inner {
    max-width: 920px;
  }

  .breadcrumbs {
    display: flex;
    gap: 8px;
    margin-bottom: 56px;
    color: var(--ink-500);
    font-size: 11px;
  }

  .breadcrumbs a:hover {
    color: var(--sea-700);
  }

  .article-kicker {
    display: flex;
    gap: 16px;
    margin-bottom: 24px;
    color: var(--ink-500);
    font-size: 11px;
    font-weight: 750;
  }

  .article-kicker span {
    color: var(--sea-700);
  }

  .article-hero h1 {
    margin-bottom: 26px;
    font-size: clamp(38px, 6vw, 70px);
    font-weight: 880;
    letter-spacing: -0.067em;
    line-height: 1.2;
    text-wrap: balance;
  }

  .article-description {
    max-width: 760px;
    color: var(--ink-600);
    font-size: 17px;
    line-height: 1.95;
  }

  .article-audience {
    margin: 28px 0 0;
    color: var(--ink-500);
    font-size: 11px;
  }

  .article-layout {
    display: grid;
    grid-template-columns: minmax(0, 760px) 240px;
    gap: clamp(48px, 8vw, 100px);
    justify-content: center;
    padding-top: 88px;
    padding-bottom: 112px;
  }

  .article-body {
    min-width: 0;
    color: #294f5d;
    font-size: 17px;
    line-height: 2.08;
  }

  .article-body :global(h2) {
    margin: 64px 0 22px;
    padding-top: 18px;
    border-top: 1px solid var(--line);
    color: var(--ink-950);
    font-size: clamp(27px, 4vw, 36px);
    letter-spacing: -0.045em;
    line-height: 1.5;
  }

  .article-body :global(h3) {
    margin: 46px 0 18px;
    color: var(--ink-900);
    font-size: 23px;
  }

  .article-body :global(p) {
    margin-bottom: 28px;
  }

  .article-body :global(strong) {
    color: var(--ink-950);
    background: linear-gradient(transparent 66%, var(--sun-100) 66%);
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    margin: 28px 0 34px;
    padding: 26px 26px 26px 48px;
    border-radius: var(--radius-md);
    background: var(--cloud);
  }

  .article-body :global(li + li) {
    margin-top: 10px;
  }

  .article-body :global(blockquote) {
    margin: 38px 0;
    padding: 26px 30px;
    border-left: 4px solid var(--sea-500);
    color: var(--ink-900);
    background: var(--sea-50);
    font-size: 20px;
    font-weight: 750;
  }

  .article-body :global(blockquote p) {
    margin: 0;
  }

  .article-aside {
    position: sticky;
    top: calc(var(--header-height) + 34px);
    align-self: start;
    padding-top: 8px;
  }

  .article-aside > div {
    margin-bottom: 22px;
    padding-bottom: 22px;
    border-bottom: 1px solid var(--line);
  }

  .article-aside > div span {
    display: block;
    margin-bottom: 8px;
    color: var(--sea-700);
    font-size: 9px;
    font-weight: 850;
    letter-spacing: 0.16em;
  }

  .article-aside strong {
    font-size: 17px;
  }

  .article-aside p {
    margin: 10px 0 0;
    color: var(--ink-500);
    font-size: 11px;
  }

  .article-end {
    background: var(--cloud);
  }

  .article-end-inner {
    display: flex;
    gap: 42px;
    align-items: flex-end;
    justify-content: space-between;
  }

  .article-end h2 {
    margin-bottom: 14px;
    font-size: clamp(30px, 5vw, 48px);
    letter-spacing: -0.055em;
  }

  .article-end p:not(.eyebrow) {
    max-width: 680px;
    margin: 0;
    color: var(--ink-600);
  }

  .article-end .button {
    flex: 0 0 auto;
  }

  @media (max-width: 860px) {
    .article-layout {
      grid-template-columns: 1fr;
    }

    .article-aside {
      position: static;
      padding-top: 30px;
      border-top: 1px solid var(--line);
    }

    .article-end-inner {
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (max-width: 680px) {
    .article-hero {
      padding: calc(var(--header-height) + 50px) 0 64px;
    }

    .breadcrumbs {
      margin-bottom: 38px;
    }

    .article-description {
      font-size: 15px;
    }

    .article-layout {
      padding-top: 60px;
      padding-bottom: 78px;
    }

    .article-body {
      font-size: 16px;
    }

    .article-body :global(ul),
    .article-body :global(ol) {
      padding: 22px 20px 22px 38px;
    }
  }
</style>
