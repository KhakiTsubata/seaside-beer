---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const entries = (await getCollection('insights', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
const dateFormatter = new Intl.DateTimeFormat('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' });
---

<BaseLayout
  title="Journal｜SeasideBeer"
  description="企業のAI導入、実務研修、若者のAI人材育成について、SeasideBeerが現場で決めたことと試したことを記録します。"
  image="/og.png"
>
  <section class="page-hero journal-hero">
    <div class="container-wide journal-title">
      <p class="eyebrow">JOURNAL / INSIGHTS & NOTES</p>
      <h1>現場で決めたことを、<br /><em>残していく。</em></h1>
      <p class="lead">新しいツールの紹介より、どの仕事を任せたか、研修で何を完成させたか、若者の作品をどう企業へ見せるかを書きます。</p>
    </div>
  </section>

  <section class="entries-section">
    <div class="container-wide">
      <div class="entries-head" data-reveal><span>INDEX / {String(entries.length).padStart(2, '0')} ENTRIES</span><span>SEASIDEBEER JOURNAL</span></div>
      <div class="entry-list">
        {entries.map((entry, index) => (
          <a class="entry-item" href={`/insights/${entry.id}/`} data-reveal>
            <span class="entry-no">{String(index + 1).padStart(2, '0')}</span>
            <div class="entry-meta"><span>{entry.data.category}</span><time datetime={entry.data.publishedAt.toISOString()}>{dateFormatter.format(entry.data.publishedAt)}</time></div>
            <div><h2>{entry.data.title}</h2><p>{entry.data.description}</p></div>
            <i aria-hidden="true">↗</i>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-compact section-cloud">
    <div class="container-wide cta-panel" data-reveal>
      <p class="eyebrow">SHARE A QUESTION</p>
      <h2>いま困っていることを、次の記事へ。</h2>
      <p>会社名や機密情報は出さず、同じ悩みを持つ企業や教育関係者が使える形で考えます。</p>
      <a class="button button-primary" href="/contact/">テーマを送る <span aria-hidden="true">↗</span></a>
    </div>
  </section>
</BaseLayout>

<style>
  .journal-hero::before { top: -18%; right: -5%; width: min(62vw,880px); aspect-ratio: 1.55; border-radius: 52% 0 0 48% / 62% 0 0 52%; background: linear-gradient(90deg, rgba(206,245,255,.18), rgba(4,71,142,.08)), url('/images/talent-detail.webp') center / cover; box-shadow: inset 0 0 0 1px rgba(255,255,255,.5), 0 28px 90px rgba(4,71,142,.1); opacity: .45; }
  .journal-title { position: relative; z-index: 1; }
  .journal-title h1 em { color: var(--tide); font-family: "Noto Serif JP", serif; font-style: normal; }
  .entries-section { padding: clamp(100px,13vw,180px) 0; background: var(--paper); }
  .entries-head { display: flex; justify-content: space-between; padding-bottom: 18px; border-bottom: 1px solid var(--line); color: var(--muted); font-size: 8px; letter-spacing: .15em; }
  .entry-item { display: grid; grid-template-columns: 54px 170px 1fr 42px; gap: 28px; align-items: start; padding: 38px 0; border-bottom: 1px solid var(--line); transition: padding .25s ease, color .25s ease; }
  .entry-item:hover { padding-right: 14px; padding-left: 14px; color: var(--blue); }
  .entry-no { color: var(--blue); font-size: 9px; }
  .entry-meta { display: grid; gap: 5px; color: var(--muted); font-size: 9px; }
  .entry-meta span { color: var(--blue); font-weight: 700; }
  .entry-item h2 { margin: 0 0 10px; font-size: clamp(24px,3vw,42px); font-weight: 500; letter-spacing: -.055em; line-height: 1.3; }
  .entry-item p { max-width: 720px; margin: 0; color: var(--ink-600); font-size: 12px; }
  .entry-item i { font-size: 26px; font-style: normal; }
  @media (max-width: 760px) {
    .entry-item { grid-template-columns: 34px 1fr 28px; gap: 14px; }
    .entry-meta { grid-column: 2; display: flex; gap: 10px; }
    .entry-item > div:last-of-type { grid-column: 2; }
    .entry-item i { grid-column: 3; grid-row: 1 / 3; }
  }
</style>
