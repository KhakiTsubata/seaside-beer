---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import { site } from '../data/site';
---

<BaseLayout
  title="お問い合わせ｜SeasideBeer"
  description="企業向けAI研修、AI導入支援、人材育成、大学・地域連携についてSeasideBeerへご相談ください。"
  image="/og.png"
>
  <section class="page-hero contact-hero">
    <div class="container-wide contact-head">
      <p class="eyebrow">START A CONVERSATION</p>
      <h1>まだ名前のない、<br /><em>相談から。</em></h1>
      <p class="lead">使うツールが決まっていなくても、今の仕事の手順が分かれば始められます。毎週時間を取られていることを教えてください。</p>
    </div>
  </section>

  <section class="contact-section">
    <div class="container-wide contact-grid">
      <aside class="contact-aside" data-reveal>
        <p class="section-index">BEFORE YOU SEND</p>
        <h2>相談できること</h2>
        <ul>
          <li><span>01</span>経営者・管理職向けAI体験</li>
          <li><span>02</span>社員向け生成AI研修</li>
          <li><span>03</span>AI導入・業務改善・制作</li>
          <li><span>04</span>学生・若者向けAI講座</li>
          <li><span>05</span>大学・行政・企業との連携</li>
          <li><span>06</span>取材・登壇・共同企画</li>
        </ul>
        <div class="direct-mail"><span>DIRECT EMAIL</span><a href={`mailto:${site.email}`}>{site.email}</a></div>
      </aside>
      <div data-reveal><ContactForm /></div>
    </div>
  </section>

  <section class="faq-section">
    <div class="container-wide faq-grid">
      <header data-reveal><p class="section-index">FAQ</p><h2>相談前に、<br />よく聞かれること。</h2></header>
      <div class="faq-list" data-reveal>
        <details><summary>まだ導入するAIツールを決めていません。</summary><p>問題ありません。先に対象業務と確認方法を整理し、その条件に合うツールを選びます。</p></details>
        <details><summary>愛媛県外やオンラインでも相談できますか。</summary><p>オンラインで対応できます。対面が必要な場合は、場所と日程を確認して個別に調整します。</p></details>
        <details><summary>研修の料金は決まっていますか。</summary><p>参加人数、回数、題材、制作支援の範囲によって変わるため、内容を確認してお見積もりします。</p></details>
        <details><summary>学生講座への協賛や課題提供を相談できますか。</summary><p>相談できます。人材紹介を前提にせず、講座支援、成果発表、匿名化した企業課題の提供など、安全な形から検討します。</p></details>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-hero::before { top: -28%; right: -6%; width: min(64vw,900px); aspect-ratio: 1.6; border-radius: 50%; background: linear-gradient(90deg, rgba(205,244,255,.18), rgba(4,71,142,.06)), url('/images/setouchi-water.webp') center 60% / cover; box-shadow: inset 0 0 0 1px rgba(255,255,255,.55), 0 28px 90px rgba(4,71,142,.1); opacity: .48; }
  .contact-head { position: relative; z-index: 1; }
  .contact-head h1 em { color: var(--tide); font-family: "Noto Serif JP", serif; font-style: normal; }
  .contact-section { padding: clamp(100px,13vw,180px) 0; background: var(--paper); }
  .contact-grid { display: grid; grid-template-columns: .72fr 1.28fr; gap: clamp(60px,9vw,130px); align-items: start; }
  .contact-aside { position: sticky; top: calc(var(--header-height) + 34px); }
  .contact-aside h2 { margin: 0 0 36px; font-size: clamp(42px,5vw,66px); font-weight: 500; letter-spacing: -.07em; }
  .contact-aside ul { margin: 0; padding: 0; border-top: 1px solid var(--line); list-style: none; }
  .contact-aside li { padding: 14px 0; border-bottom: 1px solid var(--line); font-size: 12px; }
  .contact-aside li span { display: inline-block; width: 44px; color: var(--blue); font-size: 8px; }
  .direct-mail { margin-top: 36px; }
  .direct-mail span { display: block; margin-bottom: 6px; color: var(--blue); font-size: 8px; font-weight: 700; letter-spacing: .14em; }
  .direct-mail a { font-size: 12px; font-weight: 700; word-break: break-all; }
  .faq-section { padding: clamp(100px,13vw,180px) 0; background: var(--bone); }
  .faq-grid { display: grid; grid-template-columns: .7fr 1.3fr; gap: clamp(60px,9vw,130px); }
  .faq-grid h2 { margin: 0; font-size: clamp(48px,7vw,92px); font-weight: 500; letter-spacing: -.08em; line-height: 1; }
  .faq-list { border-top: 1px solid var(--line); }
  .faq-list details { border-bottom: 1px solid var(--line); }
  .faq-list summary { position: relative; padding: 24px 52px 24px 0; font-size: 14px; font-weight: 600; list-style: none; }
  .faq-list summary::-webkit-details-marker { display: none; }
  .faq-list summary::after { position: absolute; top: 20px; right: 4px; color: var(--blue); content: "+"; font-size: 24px; font-weight: 400; }
  .faq-list details[open] summary::after { content: "−"; }
  .faq-list details p { max-width: 680px; margin: -2px 0 24px; color: var(--ink-600); font-size: 13px; }
  @media (max-width: 880px) {
    .contact-grid,
    .faq-grid { grid-template-columns: 1fr; }
    .contact-aside { position: static; }
  }
</style>
