---
interface Props {
  eyebrow: string;
  title: string;
  lead?: string;
  align?: 'left' | 'center';
  invert?: boolean;
}

const { eyebrow, title, lead, align = 'left', invert = false } = Astro.props;
---

<div class:list={['section-heading', `align-${align}`, { invert }]}>
  <p class="eyebrow">{eyebrow}</p>
  <h2>{title}</h2>
  {lead && <p class="section-lead">{lead}</p>}
</div>
