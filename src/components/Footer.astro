---
import { book, primaryNav, site, socialLinks } from '../data/site';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-water" aria-hidden="true"></div>
  <div class="container-wide footer-lead" data-reveal>
    <p>FROM MATSUYAMA, EHIME</p>
    <h2>仕事を軽く。<br /><em>松山を、面白く。</em></h2>
    <a class="footer-contact" href="/contact/">初回無料相談 <span aria-hidden="true">→</span></a>
  </div>
  <div class="container-wide footer-grid">
    <div class="footer-brand-block">
      <a class="brand brand-footer" href="/">
        <img class="brand-mark" src="/logo-icon.png" width="240" height="240" alt="" />
        <span class="brand-word">SeasideBeer</span>
      </a>
      <p>{site.tagline}</p>
      <small>{site.location} / AI IMPLEMENTATION & TALENT DEVELOPMENT</small>
      <small class="footer-visual-note">人物・風景写真は、事業の方向を伝えるために生成したコンセプトビジュアルです。実績写真ではありません。</small>
    </div>
    <nav class="footer-column" aria-label="フッターメニュー">
      <h2>メニュー</h2>
      {primaryNav.map((item) => <a href={item.href}>{item.label}</a>)}
      <a href="/contact/">お問い合わせ</a>
    </nav>
    <div class="footer-column">
      <h2>情報</h2>
      <a href={`mailto:${site.email}`}>{site.email}</a>
      <a href={book.href} target="_blank" rel="noopener noreferrer">著書：{book.title} ↗</a>
      <a href="/privacy/">プライバシー</a>
      <a href="/legal/">特定商取引法に基づく表記</a>
      <h2 class="footer-subheading">発信</h2>
      {socialLinks.map((item) => (
        <a href={item.href} target="_blank" rel="noopener noreferrer">{item.label} ↗</a>
      ))}
    </div>
  </div>
  <div class="container-wide footer-bottom">
    <span>© {year} SEASIDEBEER</span>
    <span>BUILT BESIDE THE SETO INLAND SEA</span>
  </div>
</footer>
