---
import { primaryNav, site } from '../data/site';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container-wide footer-lead">
    <p>START A CONVERSATION</p>
    <a href="/contact/">仕事を、<br /><em>前へ。</em><span aria-hidden="true">↗</span></a>
  </div>
  <div class="container-wide footer-grid">
    <div class="footer-brand-block">
      <a class="brand brand-footer" href="/">
        <span class="brand-mark" aria-hidden="true"><i></i><i></i><i></i></span>
        <span class="brand-word"><b>SEASIDE</b><b>BEER</b></span>
      </a>
      <p>{site.tagline}</p>
      <small>{site.location} / AI IMPLEMENTATION & TALENT</small>
    </div>
    <nav class="footer-column" aria-label="フッターメニュー">
      <h2>Navigate</h2>
      {primaryNav.map((item) => <a href={item.href}>{item.label}</a>)}
      <a href="/contact/">Contact</a>
    </nav>
    <div class="footer-column">
      <h2>Connect</h2>
      <a href={`mailto:${site.email}`}>{site.email}</a>
      <a href="/privacy/">Privacy</a>
      <a href="/legal/">Legal</a>
    </div>
  </div>
  <div class="container-wide footer-bottom">
    <span>© {year} SEASIDEBEER</span>
    <span>BUILD FROM MATSUYAMA / EHIME</span>
  </div>
</footer>
